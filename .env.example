# Environment Variables for Autonomous AI System

# OpenAI API Key
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-api-key-here

# Optional: Specify OpenAI Model (default: gpt-4)
# OPENAI_MODEL=gpt-4

# Optional: Maximum tokens for responses (default: 1000)
# MAX_TOKENS=1000
